{
  "name": "client-workspace",
  "private": true,
  "workspaces": [
    "marketing",
    "app"
  ],
  "scripts": {
    "dev:marketing": "npm run dev -w marketing",
    "dev:app": "npm run dev -w app",
    "build:marketing": "npm run build -w marketing",
    "build:app": "npm run build -w app",
    "build:all": "npm run build:marketing && npm run build:app",
    "lint": "npm run lint -w marketing && npm run lint -w app"
  }
}
