# =============================================================================
# Viva client (Vite panel + optional tooling) — environment template
#
# Local (no Docker), recommended:
#   cp .env.local.example .env.local
#   Vite loads `.env.local` automatically (see https://vitejs.dev/guide/env-and-mode.html).
#
# You can also copy this file to `.env` if you prefer; `.env.local` overrides `.env`.
#
# Docker: compose sets VITE_* for the frontend container; you rarely need a file here.
# =============================================================================

# --- Panel → API (local dev) ---
# When unset, Vite proxies `/api` to http://127.0.0.1:3001 (see vite.config.ts).
# VITE_API_PROXY_TARGET=http://127.0.0.1:3001

# Only if the browser must call the API on another host (no proxy). No trailing slash.
# VITE_API_BASE_URL=http://localhost:3001

# Marketing site origin (links, “open site”, etc.). Local Next on another port, e.g. http://localhost:3002
# VITE_MARKETING_ORIGIN=http://localhost:3002

# --- Optional / legacy (trim or remove if unused) ---
# BETTER_AUTH_SECRET=replace-with-a-long-random-string
# AI_GATEWAY_BASE_URL=http://localhost:3000
# AI_GATEWAY_API_KEY=your_api_key
# AUTUMN_SECRET_KEY=
