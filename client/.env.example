# Backend API — no trailing slash.
# Leave unset in dev: browser calls `/api/...` same-origin; Vite proxies to Express (see VITE_API_PROXY_TARGET).
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_API_PROXY_TARGET=http://127.0.0.1:3002
#
# Next.js marketing app (apps/web): browser must call the API host (not :3001). Docker compose sets these for you.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3002
# INTERNAL_API_BASE_URL=http://backend:3002

# When marketing runs on another origin than the panel, set this for logout / “back to site” and
# for `/` fallback redirects. Dev defaults to http://localhost:3000 if unset. No trailing slash.
# VITE_MARKETING_ORIGIN=https://your-marketing-domain.com

