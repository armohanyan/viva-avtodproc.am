FROM node:22-bookworm-slim AS deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY marketing/package.json ./marketing/
COPY app/package.json ./app/
RUN npm ci --legacy-peer-deps

FROM node:22-bookworm-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/marketing/node_modules ./marketing/node_modules
COPY . .
ENV NEXT_TELEMETRY_DISABLED=1
ARG NEXT_PUBLIC_SITE_URL=""
ARG NEXT_PUBLIC_PANEL_URL=""
ARG NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
ENV NEXT_PUBLIC_SITE_URL=$NEXT_PUBLIC_SITE_URL
ENV NEXT_PUBLIC_PANEL_URL=$NEXT_PUBLIC_PANEL_URL
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
RUN npm run build -w marketing

FROM node:22-bookworm-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
COPY --from=builder /app/marketing/public ./marketing/public
COPY --from=builder /app/marketing/.next/standalone ./
COPY --from=builder /app/marketing/.next/static ./marketing/.next/static
EXPOSE 3001
ENV HOSTNAME="0.0.0.0"
ENV PORT=3001
CMD ["node", "marketing/server.js"]
