# Copy to .env next to docker-compose.yml (optional overrides)
# MYSQL_ROOT_PASSWORD=viva_root
# MYSQL_DATABASE=viva
# MYSQL_PUBLISH_PORT=3306
# BACKEND_PUBLISH_PORT=3002
# FRONTEND_PUBLISH_PORT=3000
# WEB_PUBLISH_PORT=3001
# DB_AUTO_SEED=1
# DB_SYNC_ALTER=0
# JWT_ACCESS_SECRET=change-me
# CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
# NEXT_PUBLIC_SITE_URL=http://localhost:3001
# NEXT_PUBLIC_PANEL_URL=http://localhost:3000
