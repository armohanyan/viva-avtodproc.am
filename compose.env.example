# Copy to `.env` next to docker-compose.yml (Docker overrides only).
# For running without Docker, use `backend/.env.example` and `client/.env.example` instead.
#
# MYSQL_ROOT_PASSWORD=viva_root
# MYSQL_DATABASE=viva
# MYSQL_PUBLISH_PORT=3306
#
# Default host ports (see docker-compose.yml header):
#   API (backend)     → 3001
#   Panel (Vite)     → 3000
#   Marketing (Next) → 5173
#
# BACKEND_PUBLISH_PORT=3001
# FRONTEND_PUBLISH_PORT=3000
# WEB_PUBLISH_PORT=5173
# DB_AUTO_SEED=1
# DB_SYNC_ALTER=0
# JWT_ACCESS_SECRET=change-me
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3001
# NEXT_PUBLIC_SITE_URL=http://localhost:5173
# NEXT_PUBLIC_PANEL_URL=http://localhost:3000
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
