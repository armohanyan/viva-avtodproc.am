# Copy to `.env` in this folder (gitignored). Docker Compose reads it for variable substitution.
#
# If `docker compose up db` fails with "bind: address already in use" on 3306, set a free host port:
# MYSQL_PUBLISH_PORT=3307
#
# Then set MYSQL_PORT in backend/.env to the same number so the API reaches Docker MySQL.
#
# --- ACBA vPOS (passed through to backend container) ---
# VPOS_MODE=development
# VPOS_ENABLED=1
# VPOS_USERNAME=vivaavtodprocam_api
# VPOS_PASSWORD=
# VPOS_BINDING_USERNAME=vivaavtodprocam_binding
# VPOS_BINDING_PASSWORD=
