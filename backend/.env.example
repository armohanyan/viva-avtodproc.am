# =============================================================================
# Backend API — environment template
#
# Local (no Docker):
#   cp .env.example .env
#   Adjust MYSQL_* for your machine (local MySQL on 127.0.0.1:3306 is typical).
#   From this folder: npm ci && npm run dev   → listens on PORT (default 3001).
#
# Docker: variables are injected by docker-compose; you can still use `.env`
# for overrides when bind-mounting this repo.
# =============================================================================

# Omit or use `development` to include message/stack on 500 responses. Use `production` to hide them.
# NODE_ENV=development
# With NODE_ENV=production, set to 1 only when you need JSON error details (e.g. staging).
# EXPOSE_ERROR_DETAILS=0

PORT=3001
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=viva
# Set to 1 only in local dev to auto-alter tables (can be destructive).
# DB_SYNC_ALTER=0
# Set to 0 to skip auto-seed when the DB is empty.
# DB_AUTO_SEED=1
# In-process booking jobs (pre-book → payment due; expire unpaid holds). Prefer `npm run jobs:bookings` on a system cron in production.
# BOOKING_CRON_ENABLED=0
# BOOKING_CRON_INTERVAL_MS=300000

# --- Auth (JWT + refresh cookie) ---
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
ACCESS_TOKEN_ACTIVE_TIME=15m
REFRESH_TOKEN_ACTIVE_TIME=7d

# OAuth redirect_uri = `{API_PUBLIC_URL}/api/v1/auth/oauth/<provider>/callback` (register that exact URL with each provider).
#
# Default below: Vite panel on :5173 with `/api` proxy to this API (typical `npm run dev` in client/).
# If you instead call the API from the browser at :3001 directly, set both to http://localhost:3001
# and register OAuth redirect URIs against that origin.
API_PUBLIC_URL=http://localhost:5173
PANEL_DEFAULT_ORIGIN=http://localhost:5173

# Optional: restrict browser origins (comma-separated). If unset, dev allows permissive CORS.
# Production: set explicit origins — `POST /auth/refresh` and `POST /auth/logout` require a matching
# `Origin` / `Referer` when this list is configured (CSRF mitigation for httpOnly refresh cookies).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001


# Google OAuth
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# Facebook
# OAUTH_FACEBOOK_APP_ID=
# OAUTH_FACEBOOK_APP_SECRET=

# Sign in with Apple
# OAUTH_APPLE_CLIENT_ID=com.example.service
# OAUTH_APPLE_TEAM_ID=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# --- Transactional email (Brevo only) ---
# https://app.brevo.com/ — API key + verified sender. If unset, password reset / invites / booking mail are skipped.
# BREVO_API_KEY=
# SENDER_EMAIL=noreply@your-verified-domain.com
