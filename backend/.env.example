# Omit or use `development` to include message/stack on 500 responses. Use `production` to hide them.
# NODE_ENV=development
# With NODE_ENV=production, set to 1 only when you need JSON error details (e.g. staging).
# EXPOSE_ERROR_DETAILS=0

PORT=3002
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=viva
# Set to 1 only in local dev to auto-alter tables (can be destructive).
# DB_SYNC_ALTER=0
# Set to 0 to skip auto-seed when the DB is empty.
# DB_AUTO_SEED=1
# In-process booking jobs (pre-book → payment due; expire unpaid holds). Prefer `npm run jobs:bookings` on a system cron in production.
# BOOKING_CRON_ENABLED=0
# BOOKING_CRON_INTERVAL_MS=300000
JWT_ACCESS_SECRET=change-me-in-production
