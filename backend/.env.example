# =============================================================================
# Backend API — environment template
#
# Local (no Docker):
#   cp .env.example .env
#   Adjust MYSQL_* for your machine (local MySQL on 127.0.0.1:3306 is typical).
#   From this folder: npm ci && npm run dev   → listens on PORT (default 3001).
#
# Docker: variables are injected by docker-compose; you can still use `.env`
# for overrides when bind-mounting this repo.
# =============================================================================

# Omit or use `development` to include message/stack on 500 responses. Use `production` to hide them.
# NODE_ENV=development
# With NODE_ENV=production, set to 1 only when you need JSON error details (e.g. staging).
# EXPOSE_ERROR_DETAILS=0

PORT=3001
LOG_LEVEL=info
LOG_DIR=logs
# Delete audit log files older than N days (default 90).
# AUDIT_LOG_RETENTION_DAYS=90
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=viva
# Set to 1 only in local dev to auto-alter tables (can be destructive).
# DB_SYNC_ALTER=0
# Set to 0 to skip auto-seed when the DB is empty.
# DB_AUTO_SEED=1
# In-process booking jobs (pre-book → payment due; expire unpaid holds). Prefer `npm run jobs:bookings` on a system cron in production.
# BOOKING_CRON_ENABLED=0
# BOOKING_CRON_INTERVAL_MS=3600000

# --- Auth (JWT + refresh cookie) ---
# Set to 1 in local dev to skip admin email OTP after login (ignored when NODE_ENV=production).
DISABLE_ADMIN_MFA=1
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
ACCESS_TOKEN_ACTIVE_TIME=15m
REFRESH_TOKEN_ACTIVE_TIME=7d

# OAuth redirect_uri = `{API_PUBLIC_URL}/api/v1/auth/oauth/<provider>/callback` (register that exact URL with each provider).
#
# Use the same hostname you type in the browser for the panel (prefer `localhost` over `127.0.0.1`).
# Mismatch breaks httpOnly refresh cookies: OAuth sets the cookie on the API host; the panel must send it on `/auth/refresh`.
#
# Typical Vite panel with `/api` proxy (recommended):
#   API_PUBLIC_URL=http://localhost:5173
# If the browser calls the API directly on this port instead:
#   API_PUBLIC_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:5173
PANEL_DEFAULT_ORIGIN=http://localhost:5173

# When the panel and API are different sites (e.g. https://app.example.com and https://api.example.com), set to 1.
# Sets the refresh cookie to SameSite=None; Secure (HTTPS required in real browsers outside localhost).
# AUTH_REFRESH_COOKIE_CROSS_SITE=1

# Optional: restrict browser origins (comma-separated). If unset, dev allows permissive CORS.
# Production: set explicit origins — `POST /auth/refresh` and `POST /auth/logout` require a matching
# `Origin` / `Referer` when this list is configured (CSRF mitigation for httpOnly refresh cookies).
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3001


# Google OAuth
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# Facebook
# OAUTH_FACEBOOK_APP_ID=
# OAUTH_FACEBOOK_APP_SECRET=

# Sign in with Apple
# OAUTH_APPLE_CLIENT_ID=com.example.service
# OAUTH_APPLE_TEAM_ID=
# OAUTH_APPLE_KEY_ID=
# OAUTH_APPLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# --- Transactional email (Brevo only) ---
# https://app.brevo.com/ — API key + verified sender. If unset, password reset / invites / booking mail are skipped.
# BREVO_API_KEY=
# SENDER_EMAIL=noreply@your-verified-domain.com
# Optional override for the logo in HTML emails (default: {API_PUBLIC_URL}/upload/logo.svg from backend/upload/logo.svg).
# EMAIL_LOGO_URL=https://your-public-origin/upload/logo.svg
# EMAIL_SUPPORT_EMAIL=support@viva.am
# EMAIL_COMPANY_NAME=Viva

# --- ACBA vPOS (ArCa EPG) ---
#
# Mode controls which EPG host is used:
#   development → https://testepg.arca.am/payment/rest/  (ACBA test terminal)
#   production  → https://epg.arca.am/payment/rest/      (live terminal)
#
# If VPOS_MODE is unset, VPOS_TEST_MODE is used (1=test, 0=live), then NODE_ENV.
#
# Simulated POS (no bank redirect): VPOS_ENABLED=0 or leave credentials empty.
# Real test payments: VPOS_ENABLED=1 + API credentials below + VPOS_MODE=development.
#
# ACBA provides three logins — only the API login is used for checkout today:
#   Web portal (manual order lookup):  vivaavtodprocam_web      — not used by this app
#   API (register / status):           vivaavtodprocam_api      → VPOS_USERNAME / VPOS_PASSWORD
#   Binding (saved cards, future):     vivaavtodprocam_binding  → VPOS_BINDING_*
#
# Merchant test portal: https://testepg.arca.am/epg_gui/#login
#
VPOS_MODE=development
VPOS_ENABLED=1
VPOS_USERNAME=vivaavtodprocam_api
# Quote if the password contains # $ or spaces (unquoted # starts a comment in .env).
VPOS_PASSWORD=
# Optional — for future card-binding features
# VPOS_BINDING_USERNAME=vivaavtodprocam_binding
# VPOS_BINDING_PASSWORD=
# Optional override (defaults follow VPOS_MODE)
# VPOS_API_BASE_URL=
# Legacy alias for VPOS_MODE (1=test, 0=live)
# VPOS_TEST_MODE=1
# AMD currency code for EPG (051 = AMD)
VPOS_CURRENCY=051
